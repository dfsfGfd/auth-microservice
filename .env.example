# ===========================================
# Auth Microservice — Environment Configuration
# ===========================================
# Скопируйте этот файл в .env и настройте переменные окружения.
# НЕ коммитьте .env в git!

# -------------------------------------------
# Server Configuration
# -------------------------------------------
# Порт HTTP сервера
SERVER_PORT=8080

# Порт gRPC сервера (если используется отдельно)
GRPC_PORT=9090

# Режим окружения: development, staging, production
ENV=development

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
# DSN для подключения к PostgreSQL
# Формат: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://auth_user:auth_password@localhost:5432/auth?sslmode=disable

# -------------------------------------------
# Redis
# -------------------------------------------
# DSN для подключения к Redis
# Формат: redis://host:port
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# JWT Configuration
# -------------------------------------------
# Секретный ключ для подписи JWT токенов
# Минимум 32 символа, используйте криптографически стойкую генерацию
# Пример генерации: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-minimum-32-characters-long

# Время жизни access токена (например: 15m, 1h, 24h)
JWT_ACCESS_TTL=15m

# Время жизни refresh токена (например: 1h, 24h, 168h)
JWT_REFRESH_TTL=336h

# Issuer (название сервиса) для JWT claims
JWT_ISSUER=auth-service

# -------------------------------------------
# Cookie Configuration
# -------------------------------------------
# Флаг Secure для cookie (true для HTTPS, false для HTTP)
COOKIE_SECURE=false

# Флаг HttpOnly для cookie (защита от XSS)
COOKIE_HTTP_ONLY=true

# SameSite политика: Strict, Lax, None
COOKIE_SAME_SITE=Lax

# Домен для cookie (опционально, оставьте пустым для текущего домена)
COOKIE_DOMAIN=

# Путь для cookie
COOKIE_PATH=/

# Время жизни refresh cookie в секундах (по умолчанию 14 дней = 1209600)
COOKIE_MAX_AGE=1209600

# -------------------------------------------
# Logging Configuration
# -------------------------------------------
# Уровень логирования: debug, info, warn, error, fatal
LOG_LEVEL=debug

# Формат логов: json, console
LOG_FORMAT=console

# Название сервиса для логирования
SERVICE_NAME=auth-service

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
# Разрешённые origin (через запятую, * для всех)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Разрешённые методы (через запятую)
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Разрешённые заголовки (через запятую)
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID

# Max age для preflight запросов (в секундах)
CORS_MAX_AGE=86400

# -------------------------------------------
# Rate Limiting (опционально)
# -------------------------------------------
# Лимит запросов в минуту для endpoints
RATE_LIMIT_REGISTER=5
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REFRESH=30
RATE_LIMIT_LOGOUT=60

# -------------------------------------------
# Health Check
# -------------------------------------------
# Путь для health check endpoint
HEALTH_CHECK_PATH=/health

# -------------------------------------------
# Graceful Shutdown
# -------------------------------------------
# Таймаут ожидания завершения запросов при shutdown (в секундах)
SHUTDOWN_TIMEOUT=30
