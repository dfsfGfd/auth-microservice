# Dockerfile для интеграционных тестов
FROM golang:1.26-alpine AS builder

WORKDIR /app

# Устанавливаем зависимости для компиляции
RUN apk add --no-cache git ca-certificates

# Копируем go.mod и go.sum
COPY go.mod go.sum ./
RUN go mod download

# Копируем исходный код
COPY . .

# Компилируем сервер
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s" -o /app/bin/server ./cmd/server

# Финальный образ
FROM alpine:3.19

WORKDIR /app

# Устанавливаем корневые сертификаты и утилиты для healthcheck
RUN apk add --no-cache ca-certificates bash netcat-openbsd

# Копируем бинарник из builder
COPY --from=builder /app/bin/server /app/server

# Копируем миграции
COPY --from=builder /app/migrations /app/migrations

# Открываем порты
EXPOSE 8080 9090

# Health check
HEALTHCHECK --interval=10s --timeout=5s --start-period=10s --retries=3 \
    CMD nc -z localhost 8080 || exit 1

# Запускаем сервер (конфигурация через переменные окружения)
CMD ["/app/server"]
