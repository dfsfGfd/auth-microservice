# Auth Microservice — Environment Variables Example
# Скопируйте этот файл в .env и заполните значения

# ==================== JWT (Обязательно) ====================
# Генерация: openssl rand -base64 32
JWT_SECRET=your-secret-key-minimum-32-characters-long

# ==================== JWT TTL ====================
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=auth-service

# ==================== Приложение ====================
APP_ENV=development
HTTP_PORT=8080
GRPC_PORT=9090

# ==================== PostgreSQL ====================
DATABASE_URL=postgres://auth_user:auth_password@postgres:5432/auth?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_CONNECTION_TIMEOUT=10

# ==================== Redis ====================
REDIS_URL=redis://redis:6379
REDIS_DB=0
REDIS_CONNECTION_TIMEOUT=5

# ==================== Логирование ====================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE_NAME=auth-service

# ==================== Rate Limiting ====================
RATE_LIMIT_REGISTER=5
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REFRESH=30
RATE_LIMIT_LOGOUT=60

# ==================== Health Check ====================
HEALTH_PATH=/health

# ==================== Graceful Shutdown ====================
SHUTDOWN_TIMEOUT=30
