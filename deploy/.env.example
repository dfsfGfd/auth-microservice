# Auth Microservice — Docker Environment Variables
# Скопируйте в .env и настройте под ваше окружение

# ==================== JWT Secret ====================
# Сгенерируйте случайный секрет для production:
#   openssl rand -base64 32
#
# Пример: JWT_SECRET=abc123... (минимум 32 символа)
JWT_SECRET=change-this-secret-in-production-use-openssl-rand-base64-32

# ==================== Application ====================
APP_ENV=development

# ==================== Database ====================
DATABASE_URL=postgres://auth_user:auth_password@postgres:5432/auth?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_CONNECTION_TIMEOUT=10

# ==================== Redis ====================
REDIS_URL=redis://redis:6379
REDIS_DB=0
REDIS_CONNECTION_TIMEOUT=5

# ==================== JWT ====================
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=336h
JWT_ISSUER=auth-service

# ==================== Logging ====================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE_NAME=auth-service

# ==================== CORS ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# ==================== Rate Limiting ====================
RATE_LIMIT_REGISTER=5
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REFRESH=30
RATE_LIMIT_LOGOUT=60

# ==================== Health & Shutdown ====================
HEALTH_PATH=/health
SHUTDOWN_TIMEOUT=30
