# Auth Microservice - Production Environment Variables
# Скопируйте в .env.production и настройте под ваше окружение

# ==================== Database ====================
DB_USER=auth_user
DB_PASSWORD=change-this-to-secure-password-in-production
DB_NAME=auth

# ==================== Redis ====================
REDIS_PASSWORD=change-this-to-secure-password-in-production

# ==================== JWT ====================
# Обязательно! Генерируйте через: openssl rand -base64 32
JWT_SECRET=change-this-to-crypto-random-32-characters-long

# ==================== Application ====================
APP_ENV=production
LOG_LEVEL=warn
LOG_FORMAT=json

# ==================== CORS ====================
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com
CORS_ALLOW_CREDENTIALS=true

# ==================== Rate Limiting ====================
RATE_LIMIT_REGISTER=5
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REFRESH=30
RATE_LIMIT_LOGOUT=60
